SG_GTA_WASTED_EDGE_HIGH_THRESHOLD=180
SG_GTA_WASTED_DEBUG_ENABLED=true
SG_GTA_WASTED_DEBUG_SCORE_THRESHOLD=0.65
SG_GTA_WASTED_DEBUG_MAX_SAVES=25
SG_GTA_WASTED_DEBUG_SAVE_FIRST_N=5
SG_COMMENTARY_CONTEXT_FRAME_COUNT=5
SG_COMMENTARY_RECENT_EVENT_LIMIT=5
SG_TARGET_FPS=12
