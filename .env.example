SG_ENV=dev
SG_LOG_LEVEL=INFO
SG_DATA_DIR=data
SG_DEBUG=true
SG_CAPTURE_BACKEND=dxcam
SG_CAPTURE_MONITOR_ID=0
SG_REPLAY_BUFFER_SECONDS=10
SG_REPLAY_BUFFER_FPS=4
SG_REPLAY_BUFFER_MAX_WIDTH=640
